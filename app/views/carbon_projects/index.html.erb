<div class="page-container">
  <h1>Carbon Projects</h1>
  <p class="subtitle">
    Overview of registered carbon projects. Showing <%= @projects.size %> of <%= @total %> records (page <%= @page %> of <%= @total_pages %>).
  </p>

  <div class="per-page-controls">
    <span style="color: #5a6b52; font-size: 0.9rem;">Show:</span>
    <% [5, 10, 20, 50].each do |size| %>
      <%= link_to " #{size} ", carbon_projects_path(per_page: size, page: 1),
                  class: (@per_page == size ? "per-page-btn active" : "per-page-btn") %>
    <% end %>
  </div>

  <% if @projects.any? %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Country</th>
          <th>Region</th>
          <th>Status</th>
          <th>Total Credits Issued</th>
        </tr>
      </thead>
      <tbody>
        <% @projects.each do |project| %>
          <tr>
            <td><%= project.name %></td>
            <td><%= project.country %></td>
            <td><%= project.region %></td>
            <td>
              <span class="status-badge status-<%= project.status.downcase %>">
                <%= project.status %>
              </span>
            </td>
            <td class="credits-value">
              <%= number_to_currency(project.total_credits_issued, unit: "", precision: 2) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="pagination">
      <% if @page > 1 %>
        <%= link_to "← Previous", carbon_projects_path(page: @page - 1, per_page: @per_page), class: "prev-link" %>
      <% else %>
        <span style="opacity: 0.3;">← Previous</span>
      <% end %>

      <% (1..@total_pages).each do |p| %>
        <% if p == @page %>
          <span class="current"><%= p %></span>
        <% else %>
          <%= link_to p, carbon_projects_path(page: p, per_page: @per_page) %>
        <% end %>
      <% end %>

      <% if @page < @total_pages %>
        <%= link_to "Next →", carbon_projects_path(page: @page + 1, per_page: @per_page), class: "next-link" %>
      <% else %>
        <span style="opacity: 0.3;">Next →</span>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p>No carbon projects found. Run `bin/rails db:seed` to populate demo data.</p>
    </div>
  <% end %>
</div>
